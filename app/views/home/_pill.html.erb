<span class="inline-flex items-center gap-1 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 text-xs px-2 py-1">
  <span data-pill-name><%= name %></span>
  <button type="button" class="hover:text-blue-600 dark:hover:text-blue-400 border-white-500"
          aria-label="Remove <%= name %>"
          data-action="click->theaters-autocomplete#removePill"
          data-name="<%= name %>">×</button>
  <input type="hidden" name="theaters[]" value="<%= name %>">
</span>
