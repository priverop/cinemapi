<%= form_with(url: root_path,
              method: :get,
              data: { turbo_frame: "movies", turbo_action: "advance", controller: "auto-submit", action: "change->auto-submit#submit" },
              class: "flex flex-col gap-4") do |form| %>
  <div class="flex flex-col gap-1"
       data-controller="theaters-autocomplete"
       data-theaters-autocomplete-url-value="<%= theater_search_path %>">
    <%= form.label :theaters, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>

    <div class="flex flex-wrap gap-1" data-theaters-autocomplete-target="pills">
      <% Array(params[:theaters]).each do |name| %>
        <%= render "pill", name: name %>
      <% end %>
    </div>

    <template data-theaters-autocomplete-target="template">
      <%= render "pill", name: "" %>
    </template>

    <div class="relative">
      <input type="text" placeholder="Search theater..."
             class="input-field w-full"
             data-theaters-autocomplete-target="input"
             data-action="input->theaters-autocomplete#search blur->theaters-autocomplete#hideResults">

      <ul class="hidden absolute z-10 w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg shadow-md max-h-48 overflow-auto"
          data-theaters-autocomplete-target="results"></ul>
    </div>
  </div>

  <div class="flex flex-col gap-1">
    <%= form.label :date, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>
    <%= form.date_field :date, value: params[:date], class: "input-field" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    <div class="flex flex-col gap-1">
      <%= form.label :from_time, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>
      <%= form.time_field :from_time, value: params[:from_time], class: "input-field" %>
    </div>

    <div class="flex flex-col gap-1">
      <%= form.label :until_time, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>
      <%= form.time_field :until_time, value: params[:until_time], class: "input-field" %>
    </div>
  </div>

  <%= render "range_field", form: form, field: :duration, min: 90, max: 300, step: 30, default: 300, unit: "min" %>
  <%= render "range_field", form: form, field: :price, min: 0, max: 20, step: 1, default: 20, unit: "€" %>

  <label class="flex items-center gap-2 cursor-pointer pt-1">
    <%= form.check_box :vose, { include_hidden: false, checked: params[:vose] == "1", class: "h-4 w-4 rounded border-gray-300 dark:border-gray-600 dark:bg-gray-700 text-blue-600 focus:ring-blue-500" } %>
    <span class="text-sm text-gray-700 dark:text-gray-200 font-medium">VOSE</span>
  </label>
<% end %>
