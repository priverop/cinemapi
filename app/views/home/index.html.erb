<main class="flex flex-col md:flex-row relative gap-6 p-5">
  <section class="w-full md:w-1/4 md:sticky md:top-5 md:self-start" aria-label="Filters">
    <details class="group bg-white dark:bg-gray-800 rounded-2xl shadow-md" data-controller="collapse-filters">
      <summary class="flex items-center justify-between cursor-pointer px-6 py-4 md:cursor-default group-open:border-b group-open:border-gray-100 dark:group-open:border-gray-700">
        <h2 class="font-bold text-2xl text-gray-900 dark:text-gray-100">Filters</h2>
        <span class="text-gray-400 hover:text-blue-500 md:hidden text-lg leading-none transition-colors">&#9776;</span>
      </summary>
      <div class="p-6">

      <%= form_with(url: root_path, 
                    method: :get, 
                    data: { turbo_frame: "movies", turbo_action: "advance", controller: "auto-submit", action: "change->auto-submit#submit" }, 
                    class: "flex flex-col gap-4") do |form| %>
        <div class="flex flex-col gap-1"
             data-controller="theaters-autocomplete"
             data-theaters-autocomplete-url-value="<%= theater_search_path %>">
          <%= form.label :theaters, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>

          <div class="flex flex-wrap gap-1" data-theaters-autocomplete-target="pills">
            <% Array(params[:theaters]).each do |name| %>
              <%= render "pill", name: name %>
            <% end %>
          </div>

          <template data-theaters-autocomplete-target="template">
            <%= render "pill", name: "" %>
          </template>

          <div class="relative">
            <input type="text" placeholder="Search theater..."
                   class="w-full rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 px-3 py-2 text-sm text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                   data-theaters-autocomplete-target="input"
                   data-action="input->theaters-autocomplete#search blur->theaters-autocomplete#hideResults">

            <ul class="hidden absolute z-10 w-full bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg shadow-md max-h-48 overflow-auto"
                data-theaters-autocomplete-target="results"></ul>
          </div>
        </div>

        <div class="flex flex-col gap-1">
          <%= form.label :date, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>
          <%= form.date_field :date, value: params[:date], class: "rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 px-3 py-2 text-sm text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <div class="flex flex-col gap-1">
            <%= form.label :from_time, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>
            <%= form.time_field :from_time, value: params[:from_time], class: "rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 px-3 py-2 text-sm text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>

          <div class="flex flex-col gap-1">
            <%= form.label :until_time, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>
            <%= form.time_field :until_time, value: params[:until_time], class: "rounded-lg border border-gray-300 dark:border-gray-600 dark:bg-gray-700 px-3 py-2 text-sm text-gray-800 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>
        </div>

        <div class="flex flex-col gap-2" data-controller="range">
          <div class="flex justify-between items-center">
            <%= form.label :duration, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>
            <span class="text-sm text-gray-800 dark:text-gray-100 font-medium"><span data-range-target="output"><%= params[:duration] || 300 %></span> min</span>
          </div>
          <%= form.range_field :duration, in: 90..300, step: 30, value: params[:duration] || 300,
              class: "slide w-full accent-blue-600",
              data: { range_target: "input", action: "input->range#update" } %>
          <div class="flex justify-between text-xs text-gray-400 dark:text-gray-500">
            <span>90 min</span><span>300 min</span>
          </div>
        </div>

        <div class="flex flex-col gap-2" data-controller="range">
          <div class="flex justify-between items-center">
            <%= form.label :price, class: "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide" %>
            <span class="text-sm text-gray-800 dark:text-gray-100 font-medium"><span data-range-target="output"><%= params[:price] || 20 %></span> €</span>
          </div>
          <%= form.range_field :price, in: 0..20, step: 1, value: params[:price] || 20,
              class: "slide w-full accent-blue-600",
              data: { range_target: "input", action: "input->range#update" } %>
          <div class="flex justify-between text-xs text-gray-400 dark:text-gray-500">
            <span>0 €</span><span>20 €</span>
          </div>
        </div>

        <label class="flex items-center gap-2 cursor-pointer pt-1">
          <%= form.check_box :vose, { include_hidden: false, checked: params[:vose] == "1", class: "h-4 w-4 rounded border-gray-300 dark:border-gray-600 dark:bg-gray-700 text-blue-600 focus:ring-blue-500" } %>
          <span class="text-sm text-gray-700 dark:text-gray-200 font-medium">VOSE</span>
        </label>
      <% end %>
      </div>
    </details>
  </section>

  <section class="h-full w-full md:w-3/4" aria-label="Movies">
    <%= turbo_frame_tag "movies" do %>
      <% display_date = params[:date].present? ? Date.parse(params[:date]).strftime("%-d %B") : "today, #{Date.today.strftime("%-d %B")}" %>
      <h2 class="font-bold text-4xl text-gray-900 dark:text-gray-100 mb-2">Movies for <%= display_date %></h2>
      <% if @movies.empty? %>
        <p class="text-gray-500 dark:text-gray-400 py-5">No results.</p>
      <% else %>
        <article class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 py-5">
          <% @movies.each do |movie, showtimes| %>
            <%= render "home/movie", movie: movie, showtimes: showtimes %>
          <% end %>
        </article>
      <% end %>
    <% end %>
  </section>
</main>
