
<%# Sidebar %>

<main class="flex relative">
  <section class="w-1/4 p-5 sticky top-0 self-start">
    <h2 class="font-semibold text-xl">Filtros</h2>

    <%= form_with(url: root_path, method: :get, class: "form contents") do |form| %>
      <div>
        <%= form.label :theaters %>
        <%= form.text_field :theaters %>
      </div>

      <div>
        <%= form.label :date %>
        <%= form.date_field :date  %>
      </div>

      <div>
        <%= form.label :time %>
        <%= form.time_field :time %>
      </div>

      <div data-controller="range">
        <%= form.label :duration %>
        <%= form.range_field :duration, in: 0..300, step: 30, class: "slide",
            data: { range_target: "input", action: "input->range#update" } %>
        <span data-range-target="output">150</span> minutes.
      </div>

      <div data-controller="range">
        <%= form.label :price %>
        <%= form.range_field :price, in: 0..20, step: 1, class: "slide",
            data: { range_target: "input", action: "input->range#update" } %>
        <span data-range-target="output">10</span>€.
      </div>

      <div>
        <%= form.label :vose %>
        <%= form.check_box :vose %>
      </div>

      <div>
        <%= form.submit "Search", class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
      </div>
    <% end %>
  </section>
  <section class="h-full w-3/4">
    <h2 class="font-bold text-4xl">Cartelera</h2>
    <article class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 p-5">
      <%= render partial: "home/movie", collection: @movies %>
    </article>
  </section>
</main>
