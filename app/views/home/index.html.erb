<main class="flex relative gap-6 p-5">
  <section class="w-1/4 sticky top-5 self-start">
    <div class="bg-white rounded-2xl shadow-md p-6">
      <h2 class="font-bold text-2xl text-gray-900 mb-5 pb-3 border-b border-gray-100">Filtros</h2>

      <%= form_with(url: root_path, method: :get, class: "flex flex-col gap-4") do |form| %>
        <div class="flex flex-col gap-1">
          <%= form.label :theaters, class: "text-xs font-semibold text-gray-500 uppercase tracking-wide" %>
          <%= form.text_field :theaters, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        </div>

        <div class="flex flex-col gap-1">
          <%= form.label :date, class: "text-xs font-semibold text-gray-500 uppercase tracking-wide" %>
          <%= form.date_field :date, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="flex flex-col gap-1">
            <%= form.label :from_time, class: "text-xs font-semibold text-gray-500 uppercase tracking-wide" %>
            <%= form.time_field :from_time, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>

          <div class="flex flex-col gap-1">
            <%= form.label :until_time, class: "text-xs font-semibold text-gray-500 uppercase tracking-wide" %>
            <%= form.time_field :until_time, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>
        </div>

        <div class="flex flex-col gap-2" data-controller="range">
          <div class="flex justify-between items-center">
            <%= form.label :duration, class: "text-xs font-semibold text-gray-500 uppercase tracking-wide" %>
            <span class="text-sm text-gray-800 font-medium"><span data-range-target="output">150</span> min</span>
          </div>
          <%= form.range_field :duration, in: 0..300, step: 30, class: "slide w-full accent-blue-600",
              data: { range_target: "input", action: "input->range#update" } %>
        </div>

        <div class="flex flex-col gap-2" data-controller="range">
          <div class="flex justify-between items-center">
            <%= form.label :price, class: "text-xs font-semibold text-gray-500 uppercase tracking-wide" %>
            <span class="text-sm text-gray-800 font-medium"><span data-range-target="output">10</span> €</span>
          </div>
          <%= form.range_field :price, in: 0..20, step: 1, class: "slide w-full accent-blue-600",
              data: { range_target: "input", action: "input->range#update" } %>
        </div>

        <label class="flex items-center gap-2 cursor-pointer pt-1">
          <%= form.check_box :vose, class: "h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
          <span class="text-sm text-gray-700 font-medium">VOSE</span>
        </label>

        <%= form.submit "Search", class: "w-full text-center rounded-lg px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold cursor-pointer transition-colors mt-2" %>
      <% end %>
    </div>
  </section>

  <section class="h-full w-3/4">
    <h2 class="font-bold text-4xl text-gray-900 mb-2">Cartelera</h2>
    <article class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 py-5">
      <% @movies.each do |movie, showtimes| %>
        <%= render "home/movie", movie: movie, showtimes: showtimes %>
      <% end %>
    </article>
  </section>
</main>
