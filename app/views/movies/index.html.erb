<% content_for :title, "Cinemapi | Backoffice | Movies" %>

<div class="flex items-center justify-between mb-5">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Movies</h1>
  <%= link_to "New movie", new_movie_path, class: "rounded px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-medium" %>
</div>

<% if @movies.any? %>
  <div class="overflow-x-auto">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 border-b border-gray-200 dark:border-gray-700">
          <th class="text-left py-2 pr-4 font-medium w-10"></th>
          <th class="text-left py-2 pr-4 font-medium">Title</th>
          <th class="text-left py-2 pr-4 font-medium">Genre</th>
          <th class="text-left py-2 pr-4 font-medium">Duration</th>
          <th class="text-left py-2 pr-4 font-medium">Source</th>
          <th class="py-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
        <% @movies.each do |movie| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 group">
            <td class="py-2 pr-4">
              <% if movie.poster.present? %>
                <%= image_tag movie_poster_url(movie), class: "h-10 w-8 object-cover rounded", alt: movie.title %>
              <% else %>
                <div class="h-10 w-8 bg-gray-100 dark:bg-gray-700 rounded flex items-center justify-center text-gray-300 dark:text-gray-600 text-xs">?</div>
              <% end %>
            </td>
            <td class="py-2 pr-4 font-medium text-gray-900 dark:text-gray-100">
              <%= link_to movie.title, movie_path(movie), class: "hover:text-red-600 dark:hover:text-red-400" %>
            </td>
            <td class="py-2 pr-4 text-gray-500 dark:text-gray-400"><%= movie.genre&.capitalize %></td>
            <td class="py-2 pr-4 text-gray-500 dark:text-gray-400 font-mono text-xs"><%= movie.duration %> min</td>
            <td class="py-2 pr-4">
              <span class="text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 rounded px-2 py-0.5"><%= movie.data_source %></span>
            </td>
            <td class="py-2 text-right">
              <div class="flex justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                <%= link_to "Edit", edit_movie_path(movie), class: "text-xs text-gray-500 dark:text-gray-400 hover:text-red-600 dark:hover:text-red-400" %>
                <%= button_to "Delete", movie, method: :delete,
                    class: "text-xs text-red-500 hover:underline cursor-pointer bg-transparent border-0 p-0",
                    data: { turbo_confirm: "Delete this movie?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-sm text-gray-400 dark:text-gray-500 py-10 text-center">No movies yet.</p>
<% end %>
