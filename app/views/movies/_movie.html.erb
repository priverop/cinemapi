<div id="<%= dom_id movie %>" class="w-full sm:w-auto my-5 space-y-5 flex justify-between">
  <div>
    <% if movie.poster.present? %>
      <img width="50" src="<%= movie.poster %>" alt="<%= movie.title %>">
    <% end %>
  </div>
  <div class="px-5">
    <h2><%= movie.title %></h2>
    <p class="text-sm"><%= movie.duration %> mins - <%= movie.genre&.capitalize %></p>
    <p class="text-sm text-gray-600"><%= movie.description %></p>
  </div>
</div>
