<% content_for :title, "Cinemapi | Backoffice | Theaters" %>

<div class="flex items-center justify-between mb-5">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Theaters</h1>
  <%= link_to "New theater", new_theater_path, class: "rounded px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-medium" %>
</div>

<% if @theaters.any? %>
  <div class="overflow-x-auto">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="text-xs uppercase tracking-wide text-gray-400 dark:text-gray-500 border-b border-gray-200 dark:border-gray-700">
          <th class="text-left py-2 pr-4 font-medium">Name</th>
          <th class="text-left py-2 pr-4 font-medium">Location</th>
          <th class="text-left py-2 pr-4 font-medium">Scraper</th>
          <th class="text-left py-2 pr-4 font-medium">Price</th>
          <th class="text-left py-2 pr-4 font-medium">Status</th>
          <th class="py-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
        <% @theaters.each do |theater| %>
          <%= render theater %>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-sm text-gray-400 dark:text-gray-500 py-10 text-center">No theaters yet.</p>
<% end %>
