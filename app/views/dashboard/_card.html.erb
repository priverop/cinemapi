<div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= title %></h3>
    <%= link_to "View all (#{count})", path, class: "text-xs text-gray-500 dark:text-gray-400 hover:text-red-600 dark:hover:text-red-400" %>
  </div>
  <% if items.any? %>
    <div class="divide-y divide-gray-100 dark:divide-gray-700">
      <% items.each do |item| %>
        <div class="py-2 flex items-center justify-between gap-2">
          <div class="min-w-0">
            <p class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate"><%= item.display_name %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= item.send(sub_info) %></p>
          </div>
          <span class="text-xs text-gray-500 dark:text-gray-400 shrink-0"><%= item.send(side_info) %> <%= side_unit %></span>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-400 dark:text-gray-500">None yet.</p>
  <% end %>
</div>
