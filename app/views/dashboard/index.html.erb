<h2 class="text-xl">Dashboard</h2>

<div class="my-4">
  <%= button_to "Run scraper now", scraper_path, method: :post, data: { turbo_confirm: "Run scraper? This may take a while." }, class: "px-3 py-2 bg-blue-600 text-white rounded cursor-pointer" %>
</div>

<div class="flex">
  <%= render "card", locals: { title: "Theaters",
                               sub_info: :location,
                               side_info: :price,
                               side_unit: "€",
                               count: @theater_count,
                               latest: @recent_theaters,
                               path: theaters_path
                              } %>

  <%= render "card", locals: { title: "Movies",
                               sub_info: :genre,
                               side_info: :duration,
                               side_unit: "mins",
                               count: @movie_count,
                               latest: @recent_movies,
                               path: movies_path
                              } %>
</div>