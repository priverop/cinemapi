<% content_for :title, "Cinemapi | Backoffice" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Dashboard</h1>
  <%= button_to "Run scraper", scraper_path, method: :post,
      data: { turbo_confirm: "Run scraper? This may take a while." },
      class: "rounded px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-medium cursor-pointer" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-5">
  <%= render "card",
      title: "Theaters",
      count: @theater_count,
      path: theaters_path,
      items: @recent_theaters,
      sub_info: :location,
      side_info: :price,
      side_unit: "€" %>

  <%= render "card",
      title: "Movies",
      count: @movie_count,
      path: movies_path,
      items: @recent_movies,
      sub_info: :genre,
      side_info: :duration,
      side_unit: "min" %>

  <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">Recent Showtimes</h3>
    </div>
    <% if @recent_showtimes.any? %>
      <div class="divide-y divide-gray-100 dark:divide-gray-700">
        <% @recent_showtimes.each do |s| %>
          <div class="py-2 flex items-center justify-between gap-2">
            <div class="min-w-0">
              <%= link_to s.movie.title, movie_path(s.movie),
                  class: "text-sm font-medium text-gray-900 dark:text-gray-100 truncate hover:text-red-600 dark:hover:text-red-400 block" %>
              <p class="text-xs text-gray-500 dark:text-gray-400 truncate"><%= s.theater.name %></p>
            </div>
            <span class="font-mono text-xs text-gray-500 dark:text-gray-400 shrink-0"><%= s.showtime.strftime("%d/%m %H:%M") %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400 dark:text-gray-500">No showtimes yet.</p>
    <% end %>
  </div>
</div>
