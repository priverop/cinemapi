#!/usr/bin/env ruby

require_relative '../config/environment'

website = Scraper::Client.read("https://www.cinesrenoir.com/cine/cines-princesa/cartelera/")
parser = Scraper::Parser.new(website)
parsed = parser.parse
normalized = Scraper::Normalizer.normalize(parsed)
theater = Theater.find(16)
importer = Scraper::Importer.new(theater:)
importer.import(normalized)

puts "Success!"