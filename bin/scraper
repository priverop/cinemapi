#!/usr/bin/env ruby
require_relative '../config/environment'

Scraper.logger = ActiveSupport::TaggedLogging.new(Logger.new($stdout))

SOURCES = {
  "renoir" => Scraper::Renoir::Orchestrator,
  "cinesa" => Scraper::Cinesa::Orchestrator
}

theaters = Theater.enabled.where.not(scraper_key: 0).where.not(website: nil)
theaters.each do |theater|
  orchestrator = SOURCES.fetch(theater.scraper_key)
  Scraper.logger.tagged("Scraper", theater.scraper_key, theater.name) do
    orchestrator.run(theater)
  rescue => e
    Scraper.logger.error("Scraping #{theater.name} failed: #{e.class}: #{e.message}.")
  end
end